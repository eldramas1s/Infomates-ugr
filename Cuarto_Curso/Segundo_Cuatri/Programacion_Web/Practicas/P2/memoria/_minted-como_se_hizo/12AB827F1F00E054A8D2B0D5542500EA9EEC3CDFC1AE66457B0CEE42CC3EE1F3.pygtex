     *
     * @param array \PYGZdl{}data
     * @return bool|User|string True si el proceso se ha realizado correctamente, un mensaje de error en caso contrario, o un objeto User si se ha creado uno nuevo
     */
    abstract public function process(array \PYGZdl{}data);

    /**
     * Añade un error a la lista de errores
     *
     * @param string \PYGZdl{}field
     * @param string \PYGZdl{}message
     * @return void
     */
    protected function addError(string \PYGZdl{}field, string \PYGZdl{}message)
    \PYGZob{}
        \PYGZdl{}this\PYGZhy{}\PYGZgt{}errors[\PYGZdl{}field] = \PYGZdl{}message;
    \PYGZcb{}
\PYGZcb{}
\end{Verbatim}
