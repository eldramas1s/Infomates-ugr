        \PYGZcb{}
    \PYGZcb{}

    public function process(array \PYGZdl{}data)
    \PYGZob{}
        \PYGZdl{}esAdulto = isset(\PYGZdl{}data[\PYGZsq{}adultez\PYGZsq{}]) \PYG{err}{\PYGZam{}\PYGZam{}} (int)\PYGZdl{}data[\PYGZsq{}adultez\PYGZsq{}] === 1;

        if (!\PYGZdl{}esAdulto) \PYGZob{}
            \PYGZdl{}this\PYGZhy{}\PYGZgt{}addError(\PYGZsq{}adultez\PYGZsq{}, \PYGZsq{}Debes ser mayor de edad\PYGZsq{});
            return false;
        \PYGZcb{}

        \PYGZdl{}user = new User([
            \PYGZsq{}nickName\PYGZsq{} =\PYGZgt{} \PYGZdl{}data[\PYGZsq{}nickName\PYGZsq{}],
            \PYGZsq{}nombre\PYGZsq{} =\PYGZgt{} \PYGZdl{}data[\PYGZsq{}nombre\PYGZsq{}],
            \PYGZsq{}email\PYGZsq{} =\PYGZgt{} \PYGZdl{}data[\PYGZsq{}email\PYGZsq{}],
            \PYGZsq{}password\PYGZsq{} =\PYGZgt{} \PYGZdl{}data[\PYGZsq{}password\PYGZsq{}],
            \PYGZsq{}admin\PYGZsq{} =\PYGZgt{} 0
        ]);

        \PYGZdl{}errores = \PYGZdl{}user\PYGZhy{}\PYGZgt{}validateUser();

        if (!empty(\PYGZdl{}errores)) \PYGZob{}
            foreach (\PYGZdl{}errores as \PYGZdl{}error) \PYGZob{}
                \PYGZdl{}this\PYGZhy{}\PYGZgt{}addError(\PYGZsq{}general\PYGZsq{}, \PYGZdl{}error);
            \PYGZcb{}
            return false;
        \PYGZcb{}

        if (User::exists(\PYGZdl{}data[\PYGZsq{}nickName\PYGZsq{}], \PYGZdl{}data[\PYGZsq{}email\PYGZsq{}])) \PYGZob{}
            \PYGZdl{}this\PYGZhy{}\PYGZgt{}addError(\PYGZsq{}general\PYGZsq{}, \PYGZsq{}Nickname o email ya en uso\PYGZsq{});
            return false;
        \PYGZcb{}

        if (!User::create(\PYGZdl{}user\PYGZhy{}\PYGZgt{}getDatos())) \PYGZob{}
            \PYGZdl{}this\PYGZhy{}\PYGZgt{}addError(\PYGZsq{}general\PYGZsq{}, \PYGZsq{}Error al crear usuario\PYGZsq{});
            return false;
        \PYGZcb{}

        return true;
    \PYGZcb{}
\PYGZcb{}
