class FormSignUp extends FormHandler
\PYGZob{}
    public function validate(array \PYGZdl{}data)
    \PYGZob{}
        \PYGZdl{}this\PYGZhy{}\PYGZgt{}errors = [];

        if (empty(\PYGZdl{}data[\PYGZsq{}nombre\PYGZsq{}])) \PYGZob{}
            \PYGZdl{}this\PYGZhy{}\PYGZgt{}addError(\PYGZsq{}nombre\PYGZsq{}, \PYGZsq{}El nombre es obligatorio\PYGZsq{});
        \PYGZcb{} elseif (strlen(\PYGZdl{}data[\PYGZsq{}nombre\PYGZsq{}]) \PYGZgt{} 30) \PYGZob{}
            \PYGZdl{}this\PYGZhy{}\PYGZgt{}addError(\PYGZsq{}nombre\PYGZsq{}, \PYGZsq{}El nombre no puede tener más de 30 caracteres\PYGZsq{});
        \PYGZcb{} elseif (!preg\PYGZus{}match(\PYGZsq{}/\PYGZca{}[A\PYGZhy{}Za\PYGZhy{}zÁÉÍÓÚáéíóúÑñÜü ]+\PYGZdl{}/\PYGZsq{}, \PYGZdl{}data[\PYGZsq{}nombre\PYGZsq{}])) \PYGZob{}
            \PYGZdl{}this\PYGZhy{}\PYGZgt{}addError(\PYGZsq{}nombre\PYGZsq{}, \PYGZsq{}El nombre solo puede contener letras y espacios\PYGZsq{});
        \PYGZcb{}

        if (empty(\PYGZdl{}data[\PYGZsq{}nickName\PYGZsq{}])) \PYGZob{}
            \PYGZdl{}this\PYGZhy{}\PYGZgt{}addError(\PYGZsq{}nickName\PYGZsq{}, \PYGZsq{}El nickname es obligatorio\PYGZsq{});
        \PYGZcb{} elseif (!preg\PYGZus{}match(\PYGZsq{}/\PYGZca{}[a\PYGZhy{}zA\PYGZhy{}Z0\PYGZhy{}9\PYGZus{}]+\PYGZdl{}/\PYGZsq{}, \PYGZdl{}data[\PYGZsq{}nickName\PYGZsq{}])) \PYGZob{}
            \PYGZdl{}this\PYGZhy{}\PYGZgt{}addError(\PYGZsq{}nickName\PYGZsq{}, \PYGZsq{}Solo letras, números y \PYGZus{}\PYGZsq{});
        \PYGZcb{} elseif (strlen(\PYGZdl{}data[\PYGZsq{}nickName\PYGZsq{}]) \PYG{p}{\PYGZlt{}} \PYG{n+nt}{3} \PYG{err}{||} \PYG{n+na}{strlen}\PYG{err}{(\PYGZdl{}}\PYG{n+na}{data}\PYG{err}{[\PYGZsq{}}\PYG{n+na}{nickName}\PYG{err}{\PYGZsq{}])} \PYG{p}{\PYGZgt{}} 30) \PYGZob{}
            \PYGZdl{}this\PYGZhy{}\PYGZgt{}addError(\PYGZsq{}nickName\PYGZsq{}, \PYGZsq{}Debe tener entre 3 y 30 caracteres\PYGZsq{});
        \PYGZcb{}

        if (empty(\PYGZdl{}data[\PYGZsq{}email\PYGZsq{}])) \PYGZob{}
            \PYGZdl{}this\PYGZhy{}\PYGZgt{}addError(\PYGZsq{}email\PYGZsq{}, \PYGZsq{}El email es obligatorio\PYGZsq{});
        \PYGZcb{} elseif (!filter\PYGZus{}var(\PYGZdl{}data[\PYGZsq{}email\PYGZsq{}], FILTER\PYGZus{}VALIDATE\PYGZus{}EMAIL)) \PYGZob{}
            \PYGZdl{}this\PYGZhy{}\PYGZgt{}addError(\PYGZsq{}email\PYGZsq{}, \PYGZsq{}Email no válido\PYGZsq{});
        \PYGZcb{}

        if (empty(\PYGZdl{}data[\PYGZsq{}password\PYGZsq{}])) \PYGZob{}
            \PYGZdl{}this\PYGZhy{}\PYGZgt{}addError(\PYGZsq{}password\PYGZsq{}, \PYGZsq{}La contraseña es obligatoria\PYGZsq{});
        \PYGZcb{} elseif (strlen(\PYGZdl{}data[\PYGZsq{}password\PYGZsq{}]) \PYG{p}{\PYGZlt{}} \PYG{n+nt}{8} \PYG{err}{||} \PYG{n+na}{strlen}\PYG{err}{(\PYGZdl{}}\PYG{n+na}{data}\PYG{err}{[\PYGZsq{}}\PYG{n+na}{password}\PYG{err}{\PYGZsq{}])} \PYG{p}{\PYGZgt{}} 15) \PYGZob{}
            \PYGZdl{}this\PYGZhy{}\PYGZgt{}addError(\PYGZsq{}password\PYGZsq{}, \PYGZsq{}Debe tener entre 8 y 15 caracteres\PYGZsq{});
        \PYGZcb{} elseif (!preg\PYGZus{}match(\PYGZsq{}/(?=.*[a\PYGZhy{}z])(?=.*[A\PYGZhy{}Z])(?=.*\PYGZbs{}d)(?=.*[\PYGZdl{}@\PYGZdl{}!\PYGZpc{}*?\PYG{err}{\PYGZam{}}.]).\PYGZob{}8,15\PYGZcb{}/\PYGZsq{}, \PYGZdl{}data[\PYGZsq{}password\PYGZsq{}])) \PYGZob{}
            \PYGZdl{}this\PYGZhy{}\PYGZgt{}addError(\PYGZsq{}password\PYGZsq{}, \PYGZsq{}Debe contener mayúscula, minúscula, número y símbolo\PYGZsq{});
        \PYGZcb{}

        if (!isset(\PYGZdl{}data[\PYGZsq{}aceptar\PYGZsq{}])) \PYGZob{}
            \PYGZdl{}this\PYGZhy{}\PYGZgt{}addError(\PYGZsq{}aceptar\PYGZsq{}, \PYGZsq{}Debes aceptar el aviso legal\PYGZsq{});
        \PYGZcb{}

        if (!isset(\PYGZdl{}data[\PYGZsq{}adultez\PYGZsq{}])) \PYGZob{}
