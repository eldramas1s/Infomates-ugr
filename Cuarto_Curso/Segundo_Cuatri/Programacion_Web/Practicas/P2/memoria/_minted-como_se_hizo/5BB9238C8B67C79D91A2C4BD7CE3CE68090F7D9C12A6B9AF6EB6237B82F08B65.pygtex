\PYG{l+s+s2}{                    AND t.place \PYGZlt{}\PYGZgt{} ?}
\PYG{l+s+s2}{                  ORDER BY t.continent, t.country, t.place}
\PYG{l+s+s2}{                  LIMIT 4\PYGZdq{}}\PYG{p}{;}

        \PYG{k}{try} \PYG{p}{\PYGZob{}}
            \PYG{n+nv}{\PYGZdl{}stmt} \PYG{o}{=} \PYG{n+nv}{\PYGZdl{}conn}\PYG{o}{\PYGZhy{}\PYGZgt{}}\PYG{n+na}{prepare}\PYG{p}{(}\PYG{n+nv}{\PYGZdl{}query}\PYG{p}{);}
            \PYG{n+nv}{\PYGZdl{}stmt}\PYG{o}{\PYGZhy{}\PYGZgt{}}\PYG{n+na}{execute}\PYG{p}{([}\PYG{n+nv}{\PYGZdl{}this}\PYG{o}{\PYGZhy{}\PYGZgt{}}\PYG{n+na}{datos}\PYG{p}{[}\PYG{l+s+s1}{\PYGZsq{}country\PYGZsq{}}\PYG{p}{],} \PYG{n+nv}{\PYGZdl{}this}\PYG{o}{\PYGZhy{}\PYGZgt{}}\PYG{n+na}{datos}\PYG{p}{[}\PYG{l+s+s1}{\PYGZsq{}place\PYGZsq{}}\PYG{p}{]]);}
            \PYG{n+nv}{\PYGZdl{}rows} \PYG{o}{=} \PYG{n+nv}{\PYGZdl{}stmt}\PYG{o}{\PYGZhy{}\PYGZgt{}}\PYG{n+na}{fetchAll}\PYG{p}{(}\PYG{n+nx}{PDO}\PYG{o}{::}\PYG{n+na}{FETCH\PYGZus{}ASSOC}\PYG{p}{);}
            \PYG{n+nv}{\PYGZdl{}relatedTrips} \PYG{o}{=} \PYG{p}{[];}
            \PYG{k}{foreach} \PYG{p}{(}\PYG{n+nv}{\PYGZdl{}rows} \PYG{k}{as} \PYG{n+nv}{\PYGZdl{}row}\PYG{p}{)} \PYG{p}{\PYGZob{}}
                \PYG{n+nv}{\PYGZdl{}relatedTrips}\PYG{p}{[]} \PYG{o}{=} \PYG{k}{new} \PYG{n+nx}{Trip}\PYG{p}{(}\PYG{n+nv}{\PYGZdl{}row}\PYG{p}{);}
            \PYG{p}{\PYGZcb{}}
            \PYG{k}{return} \PYG{n+nv}{\PYGZdl{}relatedTrips}\PYG{p}{;}
        \PYG{p}{\PYGZcb{}} \PYG{k}{catch} \PYG{p}{(}\PYG{n+nx}{PDOException} \PYG{n+nv}{\PYGZdl{}e}\PYG{p}{)} \PYG{p}{\PYGZob{}}
            \PYG{n+nb}{error\PYGZus{}log}\PYG{p}{(}\PYG{l+s+s1}{\PYGZsq{}InfoTrips::getRelatedTrips \PYGZsq{}} \PYG{o}{.} \PYG{n+nv}{\PYGZdl{}e}\PYG{o}{\PYGZhy{}\PYGZgt{}}\PYG{n+na}{getMessage}\PYG{p}{());}
            \PYG{k}{return} \PYG{p}{[];}
